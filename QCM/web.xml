<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Gestion QCM</display-name>

    <!-- Page d'accueil -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ─── Servlets ─────────────────────────────────────── -->

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.gestionqcm.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EtudiantServlet</servlet-name>
        <servlet-class>com.gestionqcm.servlet.EtudiantServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EtudiantServlet</servlet-name>
        <url-pattern>/etudiants</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>QCMServlet</servlet-name>
        <servlet-class>com.gestionqcm.servlet.QCMServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QCMServlet</servlet-name>
        <url-pattern>/qcm</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>NiveauServlet</servlet-name>
        <servlet-class>com.gestionqcm.servlet.NiveauServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NiveauServlet</servlet-name>
        <url-pattern>/niveaux</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ExamenServlet</servlet-name>
        <servlet-class>com.gestionqcm.servlet.ExamenServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExamenServlet</servlet-name>
        <url-pattern>/examens</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ClassementServlet</servlet-name>
        <servlet-class>com.gestionqcm.servlet.ClassementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ClassementServlet</servlet-name>
        <url-pattern>/classement</url-pattern>
    </servlet-mapping>

    <!-- Encodage UTF-8 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.gestionqcm.util.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

</web-app>
